# Understudy configuration. Copy to ".env" and fill in. Never commit ".env".
# These are read from the environment by orchestrator.sh and dashboard/server.py.
# (Understudy does not auto-load .env; export the vars, or `set -a; . ./.env; set +a`.)

# REQUIRED. Absolute path to your queue root (the folder that contains
# Projects/, Future/, Archive/, dashboard/, etc.). The simplest setup uses the
# cloned repo itself as the queue root.
QUEUE_ROOT=/path/to/your/queue

# OPTIONAL. Path to your LLM CLI binary. Defaults to ~/.local/bin/claude.
CLAUDE_BIN=

# OPTIONAL. Port for the local dashboard (default 8765, bound to 127.0.0.1 only).
# DASHBOARD_PORT=8765

# --- Slack intake (only if you use skills/slack-to-queue/) ---
# Your dedicated, single-member Slack channel id and your own Slack user id.
# Resolve them via the Slack MCP (slack_search_channels / slack_search_users)
# or from a message link. Leave blank to disable Slack intake.
SLACK_CHANNEL_ID=
SLACK_USER_ID=

# OPTIONAL. Chat channel for the nudge digest (dashboard/nudge_digest.py).
# NUDGE_CHANNEL=#general
